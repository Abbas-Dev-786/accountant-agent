# Browser-safe Supabase Auth configuration. The publishable key is intended for
# browser use; RLS and the FastAPI authorization boundary still protect data.
NEXT_PUBLIC_SUPABASE_URL=https://replace-with-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-project-key

# The browser may call only the AccountingOS API, never a private Supabase
# financial schema or a provider API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
