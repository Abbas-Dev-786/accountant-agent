ACCOUNTINGOS_DEPLOYMENT_ID=us-production
ACCOUNTINGOS_DEPLOYMENT_MODE=production
ACCOUNTINGOS_DATA_CLASS=live
ACCOUNTINGOS_MARKET=US
ACCOUNTINGOS_CURRENCY=USD
ACCOUNTINGOS_CONTROLLER_SUBJECT=replace-with-supabase-controller-subject
ACCOUNTINGOS_BOOTSTRAP_CONTROLLER_EMAIL=replace-with-controller@example.com
ACCOUNTINGOS_CORS_ORIGINS=http://localhost:3000
ACCOUNTINGOS_WEB_APP_URL=http://localhost:3000
# Chosen identity provider. FastAPI verifies every bearer token with Supabase
# Auth and checks the server-side organization membership; never trust a
# browser-supplied controller subject.
ACCOUNTINGOS_AUTH_PROVIDER=supabase
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-project-key
SUPABASE_AUTH_JWT_AUDIENCE=authenticated
# Keep this server-only. It is the direct TLS Postgres connection used by the
# FastAPI API/worker; it must never be a NEXT_PUBLIC_* variable.
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.replace-with-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_CONNECT_TIMEOUT=10
ACCOUNTINGOS_XERO_CLIENT_ID=replace-with-xero-oauth-client-id
ACCOUNTINGOS_XERO_CLIENT_SECRET_REF=secret://xero/production/client-secret
ACCOUNTINGOS_XERO_REFRESH_TOKEN_SECRET_REF=secret://xero/production/refresh-token
ACCOUNTINGOS_XERO_REDIRECT_URI=http://localhost:8000/api/v1/connections/xero/callback
ACCOUNTINGOS_XERO_SCOPES=offline_access accounting.settings.read accounting.contacts.read accounting.invoices.read accounting.payments.read accounting.banktransactions.read accounting.manualjournals accounting.reports.trialbalance.read accounting.reports.profitandloss.read accounting.reports.balancesheet.read
# Pin each production organization to its accountant-approved tenant. Keep the
# allowlist to the same value when the OAuth app can grant multiple tenants.
ACCOUNTINGOS_XERO_TENANT_ID=replace-with-approved-xero-tenant-id
ACCOUNTINGOS_XERO_TENANT_ALLOWLIST=replace-with-approved-xero-tenant-id
GROQ_API_KEY_REF=secret://groq/production/api-key
GROQ_MODEL=openai/gpt-oss-20b
# All provider values below are server-only. References must resolve through the
# managed secret store; do not place raw tokens in this file or in web/.env.local.
PLAID_CLIENT_ID=replace-with-plaid-client-id
PLAID_SECRET_REF=secret://plaid/production/client-secret
PLAID_ACCESS_TOKEN_REF=secret://plaid/production/access-token
PLAID_ITEM_ID=replace-with-plaid-production-item-id
ACCOUNTINGOS_PLAID_SELECTED_ACCOUNT_IDS=replace-with-approved-plaid-account-id
PLAID_WEBHOOK_URL=https://replace-with-production-host/api/v1/webhooks/plaid
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET_REF=secret://google/production/client-secret
GOOGLE_REDIRECT_URI=https://replace-with-production-host/api/v1/connections/google/callback
GOOGLE_ACCESS_TOKEN_REF=secret://google/production/access-token
ACCOUNTINGOS_GOOGLE_DRIVE_FOLDER_IDS=replace-with-production-drive-folder-id
ACCOUNTINGOS_GOOGLE_GMAIL_MAILBOX=replace-with-production-mailbox@example.com
ACCOUNTINGOS_GOOGLE_GMAIL_LABELS=replace-with-allowed-label
B2_BUCKET_NAME=replace-with-production-bucket-name
B2_KEY_ID_REF=secret://b2/production/key-id
B2_APPLICATION_KEY_REF=secret://b2/production/application-key
# The environment-file local-development secret store resolves each secret://
# reference from the equivalent SECRET_* variable and persists rotated values
# outside Git. Production must use the managed secret-store integration.
SECRET_XERO_PRODUCTION_CLIENT_SECRET=replace-with-xero-client-secret
SECRET_XERO_PRODUCTION_REFRESH_TOKEN=replace-with-xero-refresh-token
SECRET_PLAID_PRODUCTION_CLIENT_SECRET=replace-with-plaid-client-secret
SECRET_PLAID_PRODUCTION_ACCESS_TOKEN=replace-with-plaid-access-token
SECRET_GOOGLE_PRODUCTION_CLIENT_SECRET=replace-with-google-client-secret
SECRET_GOOGLE_PRODUCTION_ACCESS_TOKEN=replace-with-google-access-token
SECRET_GROQ_PRODUCTION_API_KEY=replace-with-groq-api-key
SECRET_B2_PRODUCTION_KEY_ID=replace-with-b2-key-id
SECRET_B2_PRODUCTION_APPLICATION_KEY=replace-with-b2-application-key
