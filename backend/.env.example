ACCOUNTINGOS_DEPLOYMENT_ID=demo-us
ACCOUNTINGOS_DEPLOYMENT_MODE=demo
ACCOUNTINGOS_DATA_CLASS=synthetic
ACCOUNTINGOS_MARKET=US
ACCOUNTINGOS_CURRENCY=USD
ACCOUNTINGOS_CONTROLLER_SUBJECT=demo-controller
ACCOUNTINGOS_XERO_CLIENT_ID=replace-with-xero-oauth-client-id
ACCOUNTINGOS_XERO_CLIENT_SECRET_REF=secret://xero/demo/client-secret
ACCOUNTINGOS_XERO_REFRESH_TOKEN_SECRET_REF=secret://xero/demo/refresh-token
ACCOUNTINGOS_XERO_REDIRECT_URI=http://localhost:8000/api/v1/connections/xero/callback
ACCOUNTINGOS_XERO_SCOPES=offline_access accounting.settings.read accounting.contacts.read accounting.invoices.read accounting.payments.read accounting.banktransactions.read accounting.manualjournals accounting.reports.trialbalance.read accounting.reports.profitandloss.read accounting.reports.balancesheet.read
# Optional. Empty = register every Xero organization the user grants (multi-tenant).
# Set to a comma/space-separated list of tenant ids to pin a deployment to specific
# organizations (e.g. the Xero Demo Company) so a real org cannot enter a demo.
ACCOUNTINGOS_XERO_TENANT_ALLOWLIST=
# Used by the Phase 0 baseline-fingerprint check, not by connection registration.
ACCOUNTINGOS_XERO_DEMO_TENANT_ID=replace-with-designated-demo-tenant-id
ACCOUNTINGOS_XERO_DEMO_BASELINE_FINGERPRINT=replace-with-observed-sha256
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.replace-with-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_CONNECT_TIMEOUT=10
GROQ_API_KEY=replace-with-server-side-groq-key
GROQ_MODEL=openai/gpt-oss-20b
