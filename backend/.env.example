# Production-only server configuration for the API and worker. Replace every
# placeholder in the deployment's secret/configuration manager. Never expose
# any value in this file to the browser.

# Pin the deployment to the only supported production boundary.
ACCOUNTINGOS_DEPLOYMENT_ID=us-production
ACCOUNTINGOS_DEPLOYMENT_MODE=production
ACCOUNTINGOS_DATA_CLASS=live
ACCOUNTINGOS_MARKET=US
ACCOUNTINGOS_CURRENCY=USD

# Supabase: Auth verification and the private, TLS-only Postgres connection.
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-project-key
SUPABASE_AUTH_CACHE_SECONDS=15
# For local IPv4-only networks, use the exact "Session pooler" URI from
# Supabase Dashboard -> Connect. The direct db.<project-ref> endpoint requires
# IPv6 unless the project has the IPv4 add-on.
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.replace-with-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_POOL_MAX=10
SUPABASE_DB_POOL_WAIT_SECONDS=15

# Application URLs. CORS_ORIGINS is the deployed web-app origin; WEB_APP_URL
# is where OAuth callbacks return after success.
ACCOUNTINGOS_CORS_ORIGINS=https://replace-with-web-app-host
ACCOUNTINGOS_WEB_APP_URL=https://replace-with-web-app-host

# Xero OAuth. Keep this static application credential only in the API/worker
# environment. Each connected tenant's OAuth tokens are created in Vault.
ACCOUNTINGOS_XERO_CLIENT_ID=replace-with-xero-oauth-client-id
ACCOUNTINGOS_XERO_CLIENT_SECRET=replace-with-xero-oauth-client-secret
ACCOUNTINGOS_XERO_REDIRECT_URI=https://replace-with-api-host/api/v1/connections/xero/callback
# Required production gate. List only tenant IDs explicitly approved for this
# organization; authorization fails closed when this is empty.
ACCOUNTINGOS_XERO_TENANT_ALLOWLIST=replace-with-approved-xero-tenant-id
ACCOUNTINGOS_XERO_SCOPES=offline_access accounting.settings.read accounting.contacts.read accounting.invoices.read accounting.payments.read accounting.banktransactions.read accounting.manualjournals accounting.reports.trialbalance.read accounting.reports.profitandloss.read accounting.reports.balancesheet.read

# Plaid Link. The selected Item access token is stored during onboarding.
PLAID_CLIENT_ID=replace-with-plaid-client-id
PLAID_SECRET=replace-with-plaid-client-secret
PLAID_WEBHOOK_URL=https://replace-with-api-host/api/v1/webhooks/plaid

# Google Workspace OAuth and Gmail recovery requests. Connected Workspace
# tokens are stored during onboarding.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://replace-with-api-host/api/v1/connections/google/callback

# Grounded exception explanations.
GROQ_API_KEY=replace-with-groq-api-key

# Immutable close-package archive. The bucket must have Object Lock enabled
# with this compliance retention period.
B2_BUCKET_NAME=replace-with-production-bucket-name
B2_KEY_ID=replace-with-b2-key-id
B2_APPLICATION_KEY=replace-with-b2-application-key
B2_OBJECT_LOCK_RETENTION_DAYS=2555

# Never add any provider credential to web/.env.local or a NEXT_PUBLIC_ value.
# OAuth refresh/access tokens are created and rotated in Vault automatically
# during provider onboarding; static credentials above are never read from Vault.
